{
    "build": {
        "arduino": {
            "ldscript": "esp32c5_out.ld"
        },
        "core": "esp32",
        "extra_flags": "-DARDUINO_ESP32C5_DEV -DCONFIG_BRUCE_SLAVE=1",
        "f_cpu": "160000000L",
        "f_flash": "80000000L",
        "flash_mode": "qio",
        "mcu": "esp32c5",
        "partitions": "default_4MB.csv",
        "variant": "esp32c5"
    },
    "connectivity": ["wifi", "bluetooth"],
    "debug": {
        "default_tools": ["esp-builtin"],
        "onboard_tools": ["esp-builtin"],
        "openocd_target": "esp32c5-builtin.cfg"
    },
    "frameworks": ["arduino", "espidf"],
    "name": "Bruce ESP32-C5 Slave",
    "upload": {
        "flash_size": "4MB",
        "maximum_ram_size": 400000,
        "maximum_size": 4194304,
        "require_upload_port": true,
        "speed": 921600,
        "tool": "esptool.py"
    },
    "url": "https://github.com/nam348tnh3gp/firmware",
    "vendor": "Bruce Team"
}
