{
    "build": {
        "arduino": {
            "ldscript": "esp32s3_out.ld"
        },
        "core": "esp32",
        "extra_flags": "-DARDUINO_ESP32S3_DEV",
        "f_cpu": "240000000L",
        "f_flash": "80000000L",
        "flash_mode": "qio",
        "mcu": "esp32s3",
        "partitions": "default_16MB.csv",
        "variant": "esp32s3"
    },
    "connectivity": [
        "wifi",
        "bluetooth",
        "ethernet",
        "usb"
    ],
    "debug": {
        "default_tools": [
            "esp-builtin"
        ],
        "onboard_tools": [
            "esp-builtin"
        ],
        "openocd_target": "esp32s3-builtin.cfg"
    },
    "frameworks": [
        "arduino",
        "espidf"
    ],
    "name": "Custom ESP32-S3 Master Board",
    "upload": {
        "flash_size": "16MB",
        "maximum_ram_size": 524288,
        "maximum_size": 16777216,
        "require_upload_port": true,
        "speed": 921600,
        "tool": "esptool.py"
    },
    "url": "https://github.com/BruceDevices/firmware",
    "vendor": "Bruce Team"
}
